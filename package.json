{
  "name": "trackui",
  "version": "1.3.0",
  "description": "Operation tracking, undo/redo, model validation, and dirty state management for TypeScript",
  "type": "module",
  "main": "./dist/prod/index.cjs",
  "module": "./dist/prod/index.js",
  "types": "./dist/dev/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/dev/index.d.ts",
      "development": {
        "import": "./dist/dev/index.js",
        "require": "./dist/dev/index.cjs"
      },
      "default": {
        "import": "./dist/prod/index.js",
        "require": "./dist/prod/index.cjs"
      }
    }
  },
  "author": "Nazario Mazzotti",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Katn30/TrackUI"
  },
  "keywords": [
    "trackui",
    "typescript",
    "undo-redo",
    "state-management",
    "dirty-state",
    "validation",
    "tracked"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}